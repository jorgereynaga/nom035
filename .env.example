# Django settings
SECRET_KEY=cambia-esto-por-una-clave-real
ALLOWED_HOSTS=localhost,127.0.0.1
DEBUG=False

# Database settings
POSTGRES_DB=nom035
POSTGRES_USER=nom035_user
POSTGRES_PASSWORD=cambia-esto-por-una-password-real
DATABASE_URL=postgresql://nom035_user:cambia-esto-por-una-password-real@db:5432/nom035

# Encryption and third-party integrations
AES_ENCRYPTION_KEY=cambia-esto-por-16-caracteres
RECAPTCHA_SECRET_KEY=placeholder-recaptcha-secret
RECAPTCHA_SITE_KEY=placeholder-recaptcha-site
STRIPE_PUBLIC_KEY=placeholder-stripe-public-key
STRIPE_SECRET_KEY=placeholder-stripe-secret-key
STRIPE_WEBHOOK_SECRET=placeholder-stripe-webhook-secret
ANTHROPIC_API_KEY=placeholder-anthropic-api-key

# CORS / CSRF
# Si el VPS va a usar un dominio distinto al de Railway, define aqui los dominios reales.
CORS_ALLOWED_ORIGINS=https://tu-dominio-del-vps.example
CSRF_TRUSTED_ORIGINS=https://tu-dominio-del-vps.example

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu-correo@example.com
# Advertencia: settings.py conserva un fallback hardcodeado con apariencia de credencial real
# si EMAIL_HOST_PASSWORD no se define. No dejar esta variable vacia en ningun ambiente real.
EMAIL_HOST_PASSWORD=placeholder-email-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Tu App <no-reply@example.com>

# Storage
# Debe apuntar al volumen persistente del contenedor o al path persistente del VPS.
PERSISTENT_STORAGE_ROOT=/app/persistent

# Compose / local app port
APP_PORT=8000
